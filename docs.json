            ]
          },
          {
            "group": "Widgets",
            "pages": [
              "ui-reference/widgets/game-card",
              "ui-reference/widgets/game-box",
              "ui-reference/widgets/rating",
              "ui-reference/widgets/description"
            ]
          }
        ]
      }
