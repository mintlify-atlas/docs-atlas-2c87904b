{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Flutter Games",
  "theme": "almond",
  "colors": {
    "primary": "#4CAF50",
    "light": "#81C784",
    "dark": "#388E3C"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/rayliverified/FlutterGames"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rayliverified/FlutterGames"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/overview",
              "features/game-browsing",
              "features/game-details",
              "features/hero-animations",
              "features/responsive-design"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/project-structure",
              "architecture/data-models",
              "architecture/theming"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/overview",
              "components/game-card",
              "components/game-header",
              "components/rating-widget",
              "components/screenshot-gallery"
            ]
          }
        ]
      },
      {
        "tab": "UI Reference",
        "groups": [
          {
            "group": "Pages",
            "pages": [
              "ui-reference/home-page",
              "ui-reference/games-page",
              "ui-reference/game-details-page",
              "ui-reference/movies-page",
